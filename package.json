{
  "name": "mf-tools",
  "version": "1.0.0",
  "type": "module",
  "description": "An Electron application with Vue and TypeScript",
  "main": "./out/main/index.js",
  "author": {
    "name": "Faith",
    "email": "gxlove_max@163.com"
  },
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --max-warnings 0 --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "vue-tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "prepare": "husky",
    "start": "electron-vite preview",
    "dev": "dotenv electron-vite dev",
    "dev:watch": "dotenv electron-vite dev -- -w",
    "debug": "electron-vite -- --inspect --sourcemap --remote-debugging-port=9222",
    "postinstall": "electron-builder install-app-deps",
    "build": "npm run typecheck && electron-vite build",
    "build:check": "pnpm lint && pnpm test",
    "commit": "git cz",
    "build:web": "npm run build",
    "build:unpack": "dotenv npm run build && electron-builder --dir",
    "build:win": "dotenv npm run build && electron-builder --win --x64 --arm64 --publish never",
    "build:win:x64": "dotenv npm run build && electron-builder --win --x64 --publish never",
    "build:win:arm64": "dotenv npm run build && electron-builder --win --arm64 --publish never",
    "build:mac": "dotenv npm run build && electron-builder --mac --arm64 --x64 --publish never",
    "build:mac:arm64": "dotenv npm run build && electron-builder --mac --arm64 --publish never",
    "build:mac:x64": "dotenv npm run build && electron-builder --mac --x64 --publish never",
    "build:linux": "dotenv npm run build && electron-builder --linux --x64 --arm64 --publish never",
    "build:linux:arm64": "dotenv npm run build && electron-builder --linux --arm64 --publish never",
    "build:linux:x64": "dotenv npm run build && electron-builder --linux --x64 --publish never"
  },
  "dependencies": {
